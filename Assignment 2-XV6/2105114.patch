+uint64
+sys_history(void) {
+    int num;
+    uint64 stat_ptr;  // User pointer to struct syscall_stat
+
+    
+    argint(0, &num);           // First arg: syscall number
+    argaddr(1, &stat_ptr);     // Second arg: pointer to user struct
+
+    // Validate syscall number
+    if (num < 0 || num > NUM_SYSCALLS) 
+        return -1;
+
+    // Copy stats to user space
+    struct syscall_stat stat;
+    acquire(&stats_lock);
+    stat = stats[num];  // Copy kernel data
+    release(&stats_lock);
+
+    if (copyout(myproc()->pagetable, stat_ptr, (char *)&stat, sizeof(stat)) < 0)
+        return -1;  // Failed to copy to user space
+
+    return 0;  // Success
+}
+
+uint64
+sys_getpinfo(void)
+{
+  uint64 ps_addr;
+  argaddr(0, &ps_addr);
+  if (ps_addr <= 0)
+    return -1;
+
+  struct pstat kps;
+  struct proc *p;
+  for(int i = 0; i < NPROC; i++) {
+    p = &proc[i];
+    acquire(&p->lock);
+    if(p->state != UNUSED) {
+      kps.pid[i] = p->pid;
+      kps.inuse[i] = 1;
+      kps.inQ[i] = p->queue;
+      kps.tickets_original[i] = p->tickets_original;
+      kps.tickets_current[i] = p->tickets_current;
+      kps.time_slices[i] = p->time_slices;
+    } else {
+      kps.inuse[i] = 0;
+    }
+    release(&p->lock);
+  }
+
+  // Copy the struct to user space
+  if(copyout(myproc()->pagetable, ps_addr, (char *)&kps, sizeof(kps)) < 0)
+    return -1;
+
+  return 0;
+}
+
+uint64
+sys_settickets(void)
+{
+  int n;
+  if(argint(0, &n), n < 0)
+    return -1;
+
+  if(n < 1)
+    n = DEFAULT_TICKET_COUNT;
+
+  struct proc *p = myproc();
+  acquire(&p->lock);
+  p->tickets_original = n;
+  p->tickets_current = n;
+  release(&p->lock);
+
+  return 0;
+}
