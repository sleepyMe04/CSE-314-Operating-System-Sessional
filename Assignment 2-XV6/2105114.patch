+++ b/user/dummyproc.c
@@ -0,0 +1,99 @@
+#include "kernel/types.h"
+#include "kernel/stat.h"
+#include "user/user.h"
+#include "kernel/pstat.h"
+
+#define DEFAULT_TICKET_COUNT 10
+#define WORK_ITERATIONS 100000000
+#define SLEEP_INTERVAL 5
+
+int main(int argc, char *argv[]) {
+    int tickets = DEFAULT_TICKET_COUNT;
+    
+
+    
+    if (argc == 2) {
+        tickets = atoi(argv[1]);
+        if (tickets < 1) {
+            fprintf(2, "Ticket count must be positive (using default %d)\n", DEFAULT_TICKET_COUNT);
+            tickets = DEFAULT_TICKET_COUNT;
+        }
+    }
+
+    // Set tickets for this process
+    if (settickets(tickets) < 0) {
+        fprintf(2, "Error: settickets(%d) failed\n", tickets);
+        exit(1);
+    }
+    
+
+    // Create 4 child processes with different behaviors
+    for (int i = 0; i < 4; i++) {
+        if (fork() == 0) {
+            // Child 1: Pure CPU-bound (tests lottery)
+            if (i == 0) {
+                int temp = 0;
+                float f=1.1;
+                for (int j = 0; j < WORK_ITERATIONS; j++) {
+                    f = f * 1.1 + j;
+                    if (j % 100 == 0) temp += (int)f;
+                }
+            }
+            // Child 2: Short CPU bursts with sleeps (tests queue demotion)
+            else if (i == 1) {
+                for (int j = 0; j < 4; j++) {
+                    int temp = 0;
+                    float f=1.1;
+                    for (int k = 0; k < WORK_ITERATIONS/4; k++) {
+                        f = f * 1.1 + j;
+                    if (j % 100 == 0) temp += (int)f;
+                    }
+                    sleep(SLEEP_INTERVAL);
+                }
+            }
+            // Child 3: Long CPU burst then sleep (tests boosting)
+            else if (i == 2) {
+                int temp = 0;
+                float f=1.1;
+                for (int k = 0; k < WORK_ITERATIONS/2; k++) {
+                    f = f * 1.1 + k;
+                    if (k % 100 == 0) temp += (int)f;
+                }
+                sleep(SLEEP_INTERVAL*2);
+                for (int k = 0; k < WORK_ITERATIONS/2; k++) {
+                    f = f * 1.1 + k;
+                    if (k % 100 == 0) temp += (int)f;
+                }
+            }
+            // Child 4: Mostly sleeping (tests interactive favor)
+            else {
+                for (int j = 0; j < 8; j++) {
+                    sleep(SLEEP_INTERVAL);
+                    int temp = 0;
+                    for (int k = 0; k < WORK_ITERATIONS/8; k++) {
+                        float f=1.1;
+                        f = f * 1.1 + k;
+                        if (k % 100 == 0) temp += (int)f;
+                    }
+                }
+            }
+            exit(0);
+        }
+    }
+
+    // Parent does mixed workload
+    for (int j = 0; j < 3; j++) {
+        int temp = 0;
+        for (int k = 0; k < WORK_ITERATIONS/3; k++) {
+            temp += k; // Simulate some work
+        }
+        if (j % 2 == 0) {
+            sleep(SLEEP_INTERVAL);
+        }
+    }
+
+    // Wait for all children
+    while (wait(0) >= 0);
+
+    exit(0);
+}
