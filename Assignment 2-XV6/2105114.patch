@@ -0,0 +1,50 @@
+#include "kernel/types.h"
+#include "user/user.h"
+#include "kernel/pstat.h"
+
+void print_num(int num, int width) {
+    char buf[16];
+    char *p = buf + sizeof(buf) - 1;
+    *p = '\0';
+    do {
+        *--p = '0' + num % 10;
+        num /= 10;
+    } while(num != 0);
+    
+    // Padding with spaces
+    while(p > buf + sizeof(buf) - width - 1) {
+        *--p = ' ';
+    }
+    write(1, p, buf + sizeof(buf) - p - 1);
+}
+
+int main() {
+    struct pstat ps;
+    if(getpinfo(&ps) < 0) {
+        write(1, "Error\n", 6);
+        exit(1);
+    }
+
+    // Print header
+    write(1, "|  PID| InUse|  inQ|    Orig Tickets|    Curr Tickets|   TimeSlices|\n", 70);
+    write(1, "|-----|------|-----|----------------|----------------|-------------|\n", 70);
+
+    for(int i = 0; i < NPROC; i++) {
+        if(ps.inuse[i]) {
+            write(1, "|", 1);
+            print_num(ps.pid[i], 5);
+            write(1, "|", 1);
+            print_num(ps.inuse[i], 6);
+            write(1, "|", 1);
+            print_num(ps.inQ[i], 5);
+            write(1, "|", 1);
+            print_num(ps.tickets_original[i], 16);
+            write(1, "|", 1);
+            print_num(ps.tickets_current[i], 16);
+            write(1, "|", 1);
+            print_num(ps.time_slices[i], 13);
+            write(1, "|\n", 2);
+        }
+    }
+    exit(0);
+}
