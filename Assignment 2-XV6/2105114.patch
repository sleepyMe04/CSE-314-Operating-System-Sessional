+#include "kernel/types.h"
+#include "kernel/stat.h"
+#include "user/user.h"
+#include "kernel/syscall_stat.h"
+#include "kernel/syscall.h"
+
+int main(int argc, char *argv[]) {
+    struct syscall_stat stat;
+    
+    if (argc < 2) {
+        // Print all syscalls if no args
+        for (int i = 1; i <= SYS_history; i++) {
+        
+            if (history(i, &stat) == 0  && stat.syscall_name[0] != '\0') {
+                
+                printf("%d: syscall: %s, #: %d, time: %d\n", 
+                    i, stat.syscall_name, stat.count, stat.accum_time);
+            }
+        }
+    } else {
+        // Print specific syscall
+        int num = atoi(argv[1]);
+        if (history(num, &stat) == 0) {
+            printf("%d: syscall: %s, #: %d, time: %d\n", 
+                num, stat.syscall_name, stat.count, stat.accum_time);
+        }
+    }
+    return 0;
+}
